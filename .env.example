# TrendSpec 配置模板
# 复制为 .env 并填入真实值。.env 不会进入 git。
#
# 安全提醒：
#   1. DB_USER 必须是只读账号，禁止使用 root。
#      在 NAS 端执行：
#        CREATE USER 'trendspec'@'%' IDENTIFIED BY '<强密码>';
#        GRANT SELECT ON stocks.* TO 'trendspec'@'%';
#        FLUSH PRIVILEGES;
#   2. 任何凭证泄露后，必须立刻在 NAS 端轮换。

# ===== MariaDB / MySQL（局域网 NAS） =====
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=stocks
DB_CHARSET=utf8mb4

# ===== 本地数据湖 =====
# Parquet 缓存根目录。可指向独立磁盘避免占满系统盘。
DATA_LAKE_ROOT=./data_lake

# ===== 回测参数 =====
INITIAL_CAPITAL=1000000
COMMISSION_RATE_CN=0.0003
COMMISSION_RATE_US=0.0005
STAMP_DUTY_CN=0.001
SLIPPAGE_BPS=2

# ===== 风控参数（默认值，策略可覆盖） =====
RISK_FREE_RATE=0.03
MAX_POSITION_PCT=0.10
MAX_SECTOR_PCT=0.25
DRAWDOWN_HALT_PCT=0.20

# AI 因子研究闭环（接入 DeepSeek V4 Pro 等 OpenAI 兼容后端）
RESEARCH_LLM_BASE_URL=https://api.deepseek.com/v1
RESEARCH_LLM_API_KEY=
RESEARCH_LLM_MODEL=deepseek-chat
RESEARCH_OUT_DIR=./research_out
